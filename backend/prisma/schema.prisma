// Prisma schema - Sistema de Jueceo y Control de Accesos
// Fase actual: formulario de registro + pago (Stripe)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Categoria {
  KIDS_AMATEUR
  KIDS_BOYS
  KIDS_GIRL
  MASTERS_40_PLUS
  JUVENIL_BOYS
  JUVENIL_GIRL
  BGIRLS
  BBOYS
  PUBLICO_GENERAL
  OPEN_STYLE_1V1
}

enum Sexo {
  MASCULINO
  FEMENINO
}

enum TipoBoleto {
  GENERAL
  COMPETIDOR
  STAFF
  VIP
  INVITADO
}

enum EstatusPago {
  PENDIENTE
  PAGADO
  FALLIDO
  REEMBOLSADO
}

// Paquete base elegido por el registrante; los workshops (add-on) se
// guardan aparte en workshopsSeleccionados. Ver backend/src/config/catalog.ts
// para la tabla de precios y la función que calcula el total.
// NOTA: PRO_PACKAGE se fusionó con BOSS_VIP (mismo contenido, ver Mejoras_v3).
enum PaqueteBase {
  COMPETIDOR
  PUBLICO_GENERAL
  VIP_EXPERIENCE
  BOSS_EXPERIENCE
  BOSS_VIP
  SOLO_WORKSHOPS
  // DEPRECATED: ya no es seleccionable (quitado de PAQUETES_COMPETIDOR/PAQUETES_PUBLICO
  // en backend/frontend catalog.ts). Se conserva en el enum porque hay registros de
  // prueba existentes con este valor; no quitar sin antes migrar/borrar esas filas.
  PRUEBA_PAGO
}

model Registration {
  id                    String      @id @default(uuid())

  // Datos personales
  nombres               String
  apellidos             String
  nombreArtistico       String
  fechaNacimiento       DateTime
  categoria             Categoria
  sexo                  Sexo
  estado                String
  ciudad                String
  correo                String      @unique
  telefono              String
  instagram             String?
  academiaCrew          String?
  contactoEmergencia    String?
  nacionalidad          String
  fotoUrl               String?

  // Consentimientos legales
  aceptaReglamento      Boolean     @default(false)
  aceptaAvisoPrivacidad Boolean     @default(false)
  aceptaUsoImagen       Boolean     @default(false)
  aceptaPoliticaCancelacion Boolean @default(false)

  // Boleto, paquete y pago
  tipoBoleto            TipoBoleto
  paqueteBase           PaqueteBase
  workshopsSeleccionados Int[]      @default([])
  agregarOpenStyle      Boolean     @default(false)
  precioMXNCentavos     Int
  estatusPago           EstatusPago @default(PENDIENTE)
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?

  // Acceso (se genera al confirmarse el pago, es de un solo uso)
  qrToken               String?     @unique
  qrEscaneadoEn         DateTime?

  // ID fijo de competidor (ej. "BB-023"), asignado al confirmarse el pago.
  // Se reutiliza entre años para el mismo correo, ver backend/src/routes/stripeWebhook.ts
  competidorId          String?     @unique

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([estatusPago])
  @@index([categoria])
  @@map("registrations")
}